# ================================================================================
# IBM FlashSystem Monitor para Zabbix 7.2 - Plantilla de Secretos
# ================================================================================
# ARCHIVO: secrets.env.example
# PROPÓSITO: Plantilla para configuración sensible (NO USAR EN PRODUCCIÓN)
# ================================================================================
#
# ⚠️ ADVERTENCIAS DE SEGURIDAD CRÍTICAS ⚠️
#
# 1. ESTE ES UN ARCHIVO DE EJEMPLO - NO CONTIENE CREDENCIALES REALES
# 2. NUNCA versionar este archivo en Git con datos reales
# 3. Copiar a secrets.env y completar con valores reales
# 4. Establecer permisos 600 inmediatamente después de crear
# 5. Propietario debe ser: root:zabbix (solo lectura para zabbix)
#
# COMANDOS DE SEGURIDAD (ejecutar después de crear secrets.env):
#   sudo cp secrets.env.example secrets.env
#   sudo chown root:zabbix /opt/zabbix-ibm-flash/config/secrets.env
#   sudo chmod 600 /opt/zabbix-ibm-flash/config/secrets.env
#
# REFERENCIAS DOCUMENTALES:
# - sg248561.txt: IBM Storage Virtualize V8.7 (Capítulo 4 - Security)
# - svc_bkmap_cliguidebk (1).txt: SSH key management
# - Zabbix_Documentation_7.2.en.txt: ExternalCheck security
#
# ================================================================================

# ================================================================================
# CONFIGURACIÓN DE CLAVE SSH (AUTENTICACIÓN RECOMENDADA)
# ================================================================================
# Referencia: svc_bkmap_cliguidebk (1).txt - SSH key configuration
# Referencia: sg248561.txt Capítulo 4 - User security best practices

# Ruta a la clave privada SSH ED25519
# PERMISOS REQUERIDOS: 600 (rw-------)
# PROPIETARIO REQUERIDO: zabbix:zabbix
# ALGORITMO RECOMENDADO: ED25519 (más seguro que RSA)
# LONGITUD MÍNIMA RSA: 3072 bits (si no usa ED25519)
SSH_KEY_PATH=/opt/zabbix-ibm-flash/config/id_ibm_flash

# Ruta al archivo known_hosts para verificación de host key
# PRODUCCIÓN: Debe existir y contener host keys verificados
# DESARROLLO: Puede estar vacío (usa InsecureIgnoreHostKey)
# Referencia: sg248561.txt - SSH host fingerprint verification
SSH_KNOWN_HOSTS_PATH=/opt/zabbix-ibm-flash/config/known_hosts

# ================================================================================
# CREDENCIALES DE USUARIO FLASHSYSTEM (SOLO SI NO USA SSH KEY)
# ================================================================================
# ⚠️ ADVERTENCIA: Autenticación por password NO RECOMENDADA para producción
# Referencia: sg248561.txt Capítulo 4 - Credential management
#
# MEJOR PRÁCTICA: Usar SSH_KEY_PATH en lugar de password
# Si debe usar password, encriptar con Vault o similar

# Usuario de solo lectura en FlashSystem
# REQUISITOS:
#   - securityadmin = no (solo lectura)
#   - webui = no (sin acceso GUI)
#   - ssh_key = yes (si usa autenticación por clave)
# Referencia: svc_bkmap_cliguidebk (1).txt - mkuser command
FLASHSYSTEM_USER=zabbix_monitor

# Password del usuario (SOLO DESARROLLO - NO PRODUCCIÓN)
# ⚠️ NUNCA almacenar password en texto plano en producción
# Usar HashiCorp Vault, CyberArk, o similar para gestión de secretos
# Referencia: Zabbix_Documentation_7.2.en.txt - Vault integration
# FLASHSYSTEM_PASSWORD=COMPLETAR_SOLO_PARA_PRUEBAS

# ================================================================================
# CONFIGURACIÓN DE RED Y CONEXIÓN
# ================================================================================

# IP de gestión del FlashSystem (ejemplo)
# En producción, usar variable de entorno o Vault
# Referencia: sg248561.txt - Management IP configuration (Sección 3.2.1)
# FLASHSYSTEM_MGMT_IP=192.168.1.100

# Puerto SSH (estándar: 22)
# Referencia: svc_bkmap_cliguidebk (1).txt - SSH configuration
SSH_PORT=22

# Timeout de conexión SSH (segundos)
# DEBE ser menor que Timeout en zabbix_server.conf
# Referencia: Zabbix_Documentation_7.2.en.txt - Timeout parameter
SSH_TIMEOUT=25

# ================================================================================
# CONFIGURACIÓN DE VAULT (OPCIONAL - RECOMENDADO PARA PRODUCCIÓN)
# ================================================================================
# Referencia: Zabbix_Documentation_7.2.en.txt - Vault integration (p.1045)
# Referencia: sg248561.txt - External authentication service

# Tipo de Vault (HashiCorp o CyberArk)
# VAULT_TYPE=HashiCorp

# URL del servidor Vault
# VAULT_URL=https://vault.alatreon-bank.local:8200

# Token de autenticación de Vault (ROTAR REGULARMENTE)
# VAULT_TOKEN=hvs.xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Ruta al secreto de base de datos en Vault
# VAULT_DB_PATH=secret/zabbix/database

# Ruta al secreto de macros en Vault
# VAULT_MACRO_PATH=secret/zabbix/macros

# ================================================================================
# CONFIGURACIÓN DE LOGGING SEGURO
# ================================================================================

# Ruta del archivo de log
# PERMISOS REQUERIDOS: 640 (rw-r-----)
# PROPIETARIO REQUERIDO: zabbix:zabbix
LOG_FILE_PATH=/opt/zabbix-ibm-flash/logs/ibm_flash_monitor.log

# Nivel de log (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# PRODUCCIÓN: INFO o WARNING
# TROUBLESHOOTING: DEBUG (temporal, revertir después)
LOG_LEVEL=INFO

# ================================================================================
# CONFIGURACIÓN DE AUDITORÍA
# ================================================================================
# Referencia: sg248561.txt Sección 4.2.2 - Audit log

# Habilitar logging de auditoría
AUDIT_LOG_ENABLED=true

# Habilitar checksum para integridad de logs
AUDIT_LOG_CHECKSUM=true

# Retención de logs de auditoría (días)
AUDIT_LOG_RETENTION_DAYS=90

# ================================================================================
# CONFIGURACIÓN DE ALERTAS Y NOTIFICACIONES
# ================================================================================

# Email para alertas críticas (opcional)
# ALERT_EMAIL=storage-team@alatreon-bank.local

# Webhook para integración con SIEM (opcional)
# SIEM_WEBHOOK_URL=https://siem.alatreon-bank.local/api/alerts

# ================================================================================
# CONFIGURACIÓN DE MANTENIMIENTO
# ================================================================================

# Ventana de mantenimiento (cron format)
# MAINTENANCE_WINDOW=0 2 * * 0  (Domingos 2:00 AM)

# Habilitar rotación automática de claves SSH
# SSH_KEY_ROTATION_ENABLED=false

# Intervalo de rotación de claves (días)
# SSH_KEY_ROTATION_INTERVAL_DAYS=365

# ================================================================================
# METADATOS Y CONTROL DE VERSIONES
# ================================================================================

# Versión de la configuración
CONFIG_VERSION=1.0.0

# Fecha de creación
CONFIG_CREATED=2026-01-XX

# Última modificación
CONFIG_MODIFIED=2026-01-XX

# Responsable de la configuración
CONFIG_OWNER=storage-monitoring-team@alatreon-bank.local

# ================================================================================
# INSTRUCCIONES DE USO
# ================================================================================
#
# 1. Copiar este archivo:
#    sudo cp secrets.env.example secrets.env
#
# 2. Editar con valores reales:
#    sudo vi /opt/zabbix-ibm-flash/config/secrets.env
#
# 3. Establecer permisos seguros:
#    sudo chown root:zabbix /opt/zabbix-ibm-flash/config/secrets.env
#    sudo chmod 600 /opt/zabbix-ibm-flash/config/secrets.env
#
# 4. Verificar permisos:
#    ls -la /opt/zabbix-ibm-flash/config/secrets.env
#    # Debe mostrar: -rw------- root:zabbix
#
# 5. NUNCA commit a Git:
#    # Verificar .gitignore incluye: secrets.env
#    git status
#    # secrets.env NO debe aparecer
#
# 6. Rotar credenciales regularmente:
#    - Password: cada 90 días (política bancaria)
#    - SSH Keys: cada 365 días
#    - Vault Tokens: cada 30 días
#
# ================================================================================
# COMANDOS DE VERIFICACIÓN DE SEGURIDAD
# ================================================================================
#
# # Verificar permisos del archivo
# stat -c '%a %U:%G %n' /opt/zabbix-ibm-flash/config/secrets.env
# # Esperado: 600 root:zabbix
#
# # Verificar que no está en Git
# git ls-files | grep secrets.env
# # Esperado: (sin output)
#
# # Verificar contenido (sin exponer valores)
# sudo cat /opt/zabbix-ibm-flash/config/secrets.env | grep -v '='
# # Solo debe mostrar comentarios
#
# # Verificar checksum para integridad
# sha256sum /opt/zabbix-ibm-flash/config/secrets.env
# # Registrar checksum para auditoría
#
# ================================================================================